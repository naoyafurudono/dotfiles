    "deny": [
      "Bash(kubectl:*)",
      "Bash(gh *--admin*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'CMD=$(cat | jq -r \".tool_input.command // empty\"); if echo \"$CMD\" | grep -qiE \"(imgur|imgbb|0x0\\.st|transfer\\.sh|file\\.io|pasteboard|ibb\\.co|catbox\\.moe|uguu\\.se|gyazo\\.com|firestorage\\.jp|gigafile\\.nu|data-bin\\.com|tenpu\\.me|uploader\\.jp|axfc\\.net|dotup\\.org|filesend\\.to|sendanywhere\\.com)\"; then echo \"BLOCKED: 外部アップロードサービスへの送信はセキュリティポリシーにより禁止されています\" >&2; exit 2; fi'",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash -c 'CMD=$(cat | jq -r \".tool_input.command // empty\"); if echo \"$CMD\" | grep -qE \"(^|[;&|])[[:space:]]*gh[[:space:]]\" && echo \"$CMD\" | grep -q -- \"--admin\"; then echo \"BLOCKED: gh コマンドの --admin オプションはセキュリティポリシーにより禁止されています\" >&2; exit 2; fi'",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/tmux/claude-session-save.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/tmux/claude-session-save.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"Current time: '$(date +%H:%M:%S%z)'\"}}'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".go\"))' | xargs -I {} sh -c 'gofmt -w \"$1\" && goimports -w \"$1\"' _ {}"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".md\"))' | xargs -I {} sh -c 'dprint fmt --config ~/.config/dprint/config.json --stdin \"$1\" < \"$1\" > \"$1.tmp\" && mv \"$1.tmp\" \"$1\"' _ {}"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.config/claude/statusline.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "ci-check@pepabo-marketplace": true,
    "nippo@pepabo-marketplace": true,
    "presentation@pepabo-marketplace": true,
    "slack@claude-plugins-official": true,
    "engineer-interview-qa@pepabo-marketplace": true,
    "notion@claude-plugins-official": true,
    "sentry@pepabo-marketplace": true
  },
  "language": "日本語",
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "theme": "light",
  "editorMode": "vim",
  "autoCompactEnabled": false,
  "terminalProgressBarEnabled": false,
  "teammateMode": "auto",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}
