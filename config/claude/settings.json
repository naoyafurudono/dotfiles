  "model": "claude-fable-5[1m]",
  "deniedMcpServers": [
    {
      "serverUrl": "https://mcp.canva.com/*"
    },
    {
      "serverUrl": "https://mcp.hubspot.com/*"
    },
    {
      "serverUrl": "https://mcp.figma.com/*"
    },
    {
      "serverUrl": "https://mcp.mixpanel.com/*"
    },
    {
      "serverUrl": "https://local.agent.shop-pro.localhost/*"
    }
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.config/claude/hooks/bash-guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.config/claude/hooks/gh-pr-guard.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/tmux/claude-session-save.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/tmux/claude-session-save.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"Current time: '$(date +%H:%M:%S%z)'\"}}'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/colorme-board-register.sh",
            "timeout": 60,
            "statusMessage": "colorme チームタスクボードに登録中..."
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".go\"))' | xargs -I {} sh -c 'gofmt -w \"$1\" && goimports -w \"$1\"' _ {}"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".md\"))' | xargs -I {} sh -c 'dprint fmt --config ~/.config/dprint/config.json --stdin \"$1\" < \"$1\" > \"$1.tmp\" && mv \"$1.tmp\" \"$1\"' _ {}"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.config/claude/statusline.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "presentation@pepabo-marketplace": true,
    "notion@claude-plugins-official": false,
    "sentry@pepabo-marketplace": true,
    "pepabo-slides-v2@pepabo-marketplace": true,
    "chrome-devtools-mcp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "pepabo-internal-marketplace": {
      "source": {
        "source": "git",
        "url": "git@git.pepabo.com:pepabo/pepabo-internal-marketplace.git"
      }
    }
  },
  "language": "日本語",
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "theme": "light",
  "editorMode": "vim",
  "autoCompactEnabled": false,
  "terminalProgressBarEnabled": false,
  "teammateMode": "auto",
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
